          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'analyser le repas. Essayez d'être plus précis ou utilisez la saisie manuelle."
          }
        }
      }
    },
    "Could not parse that meal. Try being more specific (e.g. \"200g chicken breast with 150g rice\").": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo analizar esa comida. Intenta ser más específico (ej. \"200g de pechuga de pollo con 150g de arroz\")."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'analyser ce repas. Essayez d'être plus précis (ex. \"200g de blanc de poulet avec 150g de riz\")."
          }
        }
      }
    },
